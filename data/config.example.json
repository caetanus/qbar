{
  "$schema": "./config.schema.json",
  "height": 28,
  "margin": 0,
  "spacing": 0,
  "x": -1,
  "y": -1,
  "position": "top",
  "exclusiveZone": true,
  "waylandLayerShell": true,
  "background": "#af263039",
  "foreground": "#eef2f7",
  "accent": "#63b3ed",
  "fontFamily": "Sans Serif",
  "fontSize": 9,
  "trayItemPadding": 2,
  "windowManager": {
    "backend": "auto"
  },
  "modules-left": [
    "Workspaces",
    "CPU",
    "Memory",
    "Network"
  ],
  "modules-center": [
    "Title"
  ],
  "modules-right": [
    "Caffeine",
    "Brightness",
    "XInput",
    "NetworkManager",
    "Temperature",
    "Sound",
    "Battery",
    "CustomTool:custom/dollar",
    "CustomTool:custom/crypto",
    "Clock",
    "Tray"
  ],
  "customTools": {
    "custom/dollar": {
      "exec": "python -u /home/caetano/.config/waybar/scripts/dollar.py --waybar",
      "return-type": "json",
      "interval": 10,
      "show-empty": false,
      "format": "{} ({percentage}%)",
      "format-icons": {
        "up": "▲",
        "down": "▼"
      },
      "exec-if": ":",
      "tooltip": false
    },
    "custom/crypto": {
      "source": "widgets/Crypto.qml",
      "ticks": [
        { "label": "BTC", "symbol": "BTCUSDT", "base": "BTC", "quote": "USDT", "icon": "crypto-icons/btc.svg", "color": "#f7931a" },
        { "label": "ETH", "symbol": "ETHUSDT", "base": "ETH", "quote": "USDT", "icon": "crypto-icons/eth.svg", "color": "#627eea" },
        { "label": "XMR", "symbol": "XMRUSDT", "base": "XMR", "quote": "USDT", "icon": "crypto-icons/xmr.svg", "color": "#ff6600" }
      ]
    }
  }
}
