{
  "$schema": "./config.schema.json",
  "height": 28,
  "margin": 0,
  "spacing": 0,
  "x": -1,
  "y": -1,
  "position": "top",
  "exclusiveZone": true,
  "waylandLayerShell": true,
  "background": "#af263039",
  "foreground": "#eef2f7",
  "accent": "#63b3ed",
  "fontFamily": "Sans Serif",
  "fontSize": 9,
  "trayItemPadding": 2,
  "windowManager": {
    "backend": "auto"
  },
  "modules-left": [
    "Workspaces",
    "CPU",
    "Memory",
    "Network"
  ],
  "modules-center": [
    "Title"
  ],
  "modules-right": [
    "Caffeine",
    "Brightness",
    "XInput",
    "NetworkManager",
    "Temperature",
    "Sound",
    "Battery",
    "CustomTool:custom/dollar",
    "CustomTool:custom/btc",
    "Clock",
    "Tray"
  ],
  "customTools": {
    "custom/dollar": {
      "exec": "python -u /home/caetano/.config/waybar/scripts/dollar.py --waybar",
      "return-type": "json",
      "interval": 10,
      "show-empty": false,
      "format": "{} ({percentage}%)",
      "format-icons": {
        "up": "▲",
        "down": "▼"
      },
      "exec-if": ":",
      "tooltip": false
    },
    "custom/btc": {
      "exec": "python -u /home/caetano/.config/waybar/scripts/btc.py --waybar",
      "return-type": "json",
      "interval": 10,
      "show-empty": false,
      "format": "{} ({percentage}%)",
      "format-icons": {
        "up": "▲",
        "down": "▼"
      },
      "exec-if": ":",
      "tooltip": false
    }
  }
}
