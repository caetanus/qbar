{
    "layer": "top",
    "position": "top",
    "height": 28,
    "margin": 0,
    "spacing": 0,
    "exclusiveZone": true,
    "waylandLayerShell": true,
    "background": "#263039af",
    "foreground": "#eef2f7",
    "accent": "#63b3ed",
    "fontFamily": "Sans Serif",
    "fontSize": 9,
    "trayItemPadding": 2,
    "animationDuration": 200,
    "animationEasing": "inoutquad",
    "windowManager": {
        "backend": "auto"
    },
    "modules-left": [
        "Workspaces",
        "CPU",
        "Memory",
        "Network"
    ],
    "modules-center": [
        "Title"
    ],
    "modules-right": [
        "Caffeine",
        "Brightness",
        "XInput",
        "NetworkManager",
        "Temperature",
        "Sound",
        "Battery",
        "CustomTool:custom/dollar",
        "CustomTool:custom/btc",
        "Clock",
        "Tray"
    ],
    "customTools": {
        "custom/dollar": {
            "exec": "python -u /home/caetano/.config/waybar/scripts/dollar.py --waybar",
            "return-type": "json",
            "interval": 10,
            "show-empty": false,
            "format": "{} ({percentage}%)",
            "format-icons": {
                "up": "▲",
                "down": "▼"
            },
            "exec-if": ":",
            "tooltip": false
        },
        "custom/btc": {
            "exec": "python -u /home/caetano/.config/waybar/scripts/btc.py --waybar",
            "return-type": "json",
            "interval": 10,
            "show-empty": false,
            "format": "{} ({percentage}%)",
            "format-icons": {
                "up": "▲",
                "down": "▼"
            },
            "exec-if": ":",
            "tooltip": false
        }
    },
    "applets": [
        "Workspaces",
        "CPU",
        "Memory",
        "Network",
        "Title",
        "Caffeine",
        "Brightness",
        "XInput",
        "NetworkManager",
        "Temperature",
        "Sound",
        "Battery",
        "CustomTool:custom/dollar",
        "CustomTool:custom/btc",
        "Clock",
        "Tray"
    ]
}
