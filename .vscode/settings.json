{
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}/build-wayland-only",
    "--background-index",
    "--clang-tidy",
    "--completion-style=detailed",
    "--header-insertion=iwyu"
  ],
  "qt-qml.qmlls.command": "${workspaceFolder}/tools/qmlls",
  "qt-qml.qmlls.arguments": [
    "--build-dir",
    "${workspaceFolder}/build-wayland-only",
    "-I",
    "${workspaceFolder}/qml",
    "-I",
    "${workspaceFolder}/src"
  ],
  "files.associations": {
    "*.qrc": "xml",
    "*.qml": "qml"
  },
  "//": "Theme files use the GTK CSS dialect (@define-color, custom props like active-fill-opacity/urgent-blink-color). The built-in CSS linter doesn't know them: silence the false errors and feed it the GTK at-rules via custom data.",
  "css.lint.unknownAtRules": "ignore",
  "css.lint.unknownProperties": "ignore",
  "css.customData": [
    ".vscode/gtk-css.json"
  ],
  "C_Cpp.default.compileCommands": "/home/caetano/lab/qbar/builddir/compile_commands.json",
  "C_Cpp.default.configurationProvider": "mesonbuild.mesonbuild"
}
