# Maintainer: Marcelo A Caetano (github.com/caetanus)
#
# Prototype AUR package — builds qbar straight from the GitHub master branch
# until a tagged release exists. Install locally with:
#     makepkg -si        (run inside this directory)
# or via an AUR helper pointed at the local dir, e.g.  yay -B ./aur
pkgname=qbar-git
_pkgname=qbar
pkgver=0.1.0
pkgrel=1
pkgdesc='Qt6/QML status bar for Wayland (wlr-layer-shell) and X11, with live CSS theming'
arch=('x86_64')
url='https://github.com/caetanus/qbar'
license=('MIT')
# Batteries included: everything qbar needs to run *correctly* on Arch is a hard
# dep, so `yay -S qbar-git` never lands you in the "builds, then half the applets
# silently break at runtime" trap (missing SVG plugin / icon theme / fonts / EDS
# daemon). Both display backends are pulled in so it works on Wayland and X11.
depends=(
  'qt6-base'
  'qt6-declarative'     # QtQuick + Controls/Templates/Effects/Shapes/Layouts QML modules
  'qt6-svg'             # SVG image plugin — themeicon + every .svg applet icon
  'qt6-websockets'      # QtWebSockets QML import — Bitcoin ticker widget
  'qt6-wayland'         # Wayland (wlr-layer-shell) support
  # NB: no wlroots dependency — the layer-shell protocol code is generated from the bundled XML
  'xcb-util-wm'         # X11 dock/strut (EWMH) integration
  'sqlite'
  'libxkbcommon'        # provides xkbregistry
  'libpulse'
  'evolution-data-server'  # libedataserver + libecal AND the Sources daemon (Calendar applet)
  'adwaita-icon-theme'  # symbolic status icons served via themeicon://
  'hicolor-icon-theme'
  'ttf-nerd-fonts-symbols' # glyph icons the bundled themes render
  'ttf-roboto'          # clean sans text font the bundled themes expect
)
optdepends=(
  'wireplumber: native WirePlumber audio backend (else libpulse)'
  'libpipewire: privacy mic/camera in-use indicator'
  'pam: qbar-lock lock screen'
  'ttf-jetbrains-mono-nerd: full JetBrains Mono Nerd Font for ricing (AUR)'
)
makedepends=(
  'git'
  'meson'
  'ninja'
  'wayland-protocols'
  'qt6-wayland'
  'libxcb'              # X11 integration
  'xcb-util-wm'
)
provides=('qbar')
conflicts=('qbar')
source=("$_pkgname::git+https://github.com/caetanus/qbar.git"
        "qml-css-engine::git+https://github.com/caetanus/qml-css-engine.git")
sha256sums=('SKIP'
            'SKIP')

prepare() {
  cd "$srcdir/$_pkgname"
  # makepkg clones submodules separately; point the vendored CSS engine at the
  # local mirror (standard AUR VCS-submodule pattern).
  git submodule init
  git config submodule.vendor/qml-css-engine.url "$srcdir/qml-css-engine"
  git -c protocol.file.allow=always submodule update
}

pkgver() {
  cd "$srcdir/$_pkgname"
  # Tagged: 1.2.3.r45.gabcdef — untagged: 0.1.0.r<commits>.g<hash>.
  # NB: `git describe | sed` would mask `git describe`'s failure behind sed's exit
  # status (the pipeline succeeds with EMPTY output → an empty pkgver → makepkg
  # aborts). With no tags yet, test describe first and fall back explicitly.
  if git describe --long --tags >/dev/null 2>&1; then
    git describe --long --tags | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
  else
    printf '0.1.0.r%s.g%s' "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
  fi
}

# --- Build options -----------------------------------------------------------
# Feature toggles passed straight to Meson. Edit them here, or override per build
# from the environment, e.g.:  _lockscreen=disabled _wireplumber=disabled makepkg -si
# Values: 'enabled' | 'disabled' | 'auto'  (auto = compiled only if its deps exist).
: "${_wayland:=enabled}"     # wlr-layer-shell (Wayland) integration
: "${_x11:=enabled}"         # X11 dock/strut (EWMH) integration
: "${_wireplumber:=auto}"    # native WirePlumber audio backend (else libpulse)
: "${_privacy:=auto}"        # mic/camera in-use indicator (needs libpipewire)
: "${_lockscreen:=auto}"     # qbar-lock lock screen (needs pam)

build() {
  # One package serves any Arch setup: every WM backend (i3/sway, Hyprland, bspwm,
  # EWMH) is compiled in and chosen at runtime; both display backends default to on.
  # -Dtests=false: a package build ships binaries, not the unit-test executables.
  local _opts=(
    --prefix=/usr
    --buildtype=release
    -Dtests=false
    -Dwayland="$_wayland"
    -Dx11="$_x11"
    -Dwireplumber="$_wireplumber"
    -Dprivacy="$_privacy"
    -Dlockscreen="$_lockscreen"
  )
  meson setup build "$_pkgname" "${_opts[@]}"

  # meson compile drives Ninja, which compiles in parallel across all cores.
  # Honour a job limit if makepkg was configured with one (MAKEFLAGS="-j4").
  local _jobs=
  [[ ${MAKEFLAGS:-} =~ -j[[:space:]]*([0-9]+) ]] && _jobs=${BASH_REMATCH[1]}
  meson compile -C build ${_jobs:+-j"$_jobs"}
}

package() {
  meson install -C build --destdir "$pkgdir"
}
